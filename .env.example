# Copy to .env and fill in your values. Do not commit .env.
# See doc/sign-in-with-google.md for Google; other providers TBD.

# --- Google OAuth (Sign in with Google) ---
# Client ID from Google Cloud Console → Credentials → OAuth client ID (Web application)
GOOGLE_CLIENT_ID=

# Optional: for server-side flows (e.g. token exchange)
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (planned) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Apple Sign In (planned) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Other / API keys ---
# Add any other secrets (e.g. backend API keys, analytics) below.
# API_KEY=
